GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
JWT_SECRET=change_this_to_a_random_64_char_string

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gitpulse?sslmode=disable

# URLs
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:8080

# Email (Resend free tier — https://resend.com)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=GitPulse <digest@yourdomain.com>

# Server
PORT=8080
